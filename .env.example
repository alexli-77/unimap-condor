# Supabase project — enables accounts, workspace cloud sync, and subscription
# entitlements. When BOTH are empty the app runs in local-only mode (all data in
# localStorage) and the account / subscribe UI degrades gracefully. Find these in
# Supabase: Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Lemon Squeezy checkout URL for the Pro plan ($6.99/mo). When set, the Pro card's
# subscribe button becomes a live checkout hand-off (prefilling email + Supabase
# user id). When empty it stays the disabled "Coming soon" placeholder.
# Example: https://your-store.lemonsqueezy.com/buy/xxxxxxxx-xxxx-xxxx
VITE_LEMONSQUEEZY_CHECKOUT_URL=

# Optional Lemon Squeezy customer portal URL. When set, a "Manage subscription"
# link appears on the Pro card. Leave empty to hide it.
VITE_LEMONSQUEEZY_PORTAL_URL=

# --- Server-side only (NOT exposed to the client; do not prefix with VITE_) ---
# These are set as Supabase Edge Function secrets, not in the frontend build.
#   supabase secrets set LEMONSQUEEZY_WEBHOOK_SECRET=...
# LEMONSQUEEZY_WEBHOOK_SECRET  -> signing secret from the Lemon Squeezy webhook
# SUPABASE_SERVICE_ROLE_KEY    -> auto-injected in the hosted runtime; set only
#                                 when running the function locally
